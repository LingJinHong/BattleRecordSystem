<view class="container" wx:if="{{detail}}">
  <view class="card">
    <view class="title">战绩详情 #{{detail.id}}</view>
    <view class="row-between mt12">
      <view class="sub-title">金额</view>
      <view class="{{Number(detail.amount) >= 0 ? 'amount-plus' : 'amount-minus'}}">{{detail.amount}}</view>
    </view>
    <view class="row-between mt12">
      <view class="sub-title">小队</view>
      <view>{{detail.teamName || detail.teamId || '-'}}</view>
    </view>
    <view class="row-between mt12">
      <view class="sub-title">时间</view>
      <view>{{detail.matchDate || detail.createTime || '-'}}</view>
    </view>
    <view class="row-between mt12">
      <view class="sub-title">备注</view>
      <view>{{detail.remark || '无'}}</view>
    </view>
  </view>
</view>
