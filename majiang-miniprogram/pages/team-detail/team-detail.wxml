<view class="container">
  <view class="card">
    <view class="title">小队详情 #{{id}}</view>
    <input class="input mt16" placeholder="输入用户ID添加成员" value="{{addUserIdInput}}" bindinput="onInput" />
    <view class="btn-primary mt16" bindtap="onAddMember">添加成员</view>
  </view>

  <view class="card">
    <view class="title">成员列表</view>
    <view class="member-item" wx:for="{{members}}" wx:key="userId">
      <view>{{item.userName || ('用户' + item.userId)}}</view>
      <view class="sub-title">ID: {{item.userId}}</view>
    </view>
    <view class="empty" wx:if="{{!members.length}}">暂无成员</view>
  </view>
</view>
