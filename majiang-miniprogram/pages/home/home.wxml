<view class="container">
    <view class="card">
        <view class="title">筛选</view>
        <view class="filter-grid">
            <view style="width:100%;display: flex;justify-content: space-between;">
                <picker mode="date" bindchange="onStartDateChange">
                    <view class="picker">开始时间：{{filters.startTime || '请选择'}}</view>
                </picker>
                <picker mode="date" bindchange="onEndDateChange">
                    <view class="picker">结束时间：{{filters.endTime || '请选择'}}</view>
                </picker>
            </view>
            <view style="width:100%;display: flex;justify-content: space-between;">
                <picker range="{{teamList}}" range-key="teamName" bindchange="onTeamChange">
                    <view class="picker">小队：{{filters.teamId || '全部'}}</view>
                </picker>
                <picker range="{{typeOptions}}" range-key="label" bindchange="onTypeChange">
                    <view class="picker">收支：{{filters.incomeExpenseType === '' ? '全部' : (filters.incomeExpenseType === 1 ? '收入' : '支出')}}</view>
                </picker>
            </view>
            <!-- <picker range="{{teamList}}" range-key="teamName" bindchange="onTeamChange">
                <view class="picker">小队：{{filters.teamId || '全部'}}</view>
            </picker> -->
        </view>
        <view class="btn-primary" bindtap="onSearch">查询</view>
    </view>

    <view class="card row-between">
        <view>
            <view class="sub-title">总盈利</view>
            <view class="{{summary.totalAmount >= 0 ? 'amount-plus' : 'amount-minus'}}">{{summary.totalAmount}}</view>
        </view>
        <view>
            <view class="sub-title">局数</view>
            <view class="title">{{summary.totalCount}}</view>
        </view>
    </view>
    <view class="title" style="margin-bottom: 15rpx;">战绩列表</view>
    <view class="card match-list">
        <block wx:if="{{battleList.length}}">
            <view class="battle-item" wx:for="{{battleList}}" wx:key="id" data-item="{{item}}" bindtap="goBattle">
                <view class="row-between">
                    <view class="battle-team">{{item.teamName || '未分组'}}</view>
                    <view class="{{Number(item.score) >= 0 ? 'amount-plus' : 'amount-minus'}}">{{item.score}}</view>
                </view>
                <view class="row-between mt8">
                    <view class="sub-title">{{item.matchDate || item.createTime}}</view>
                    <view class="sub-title">{{item.remark || '无备注'}}</view>
                </view>
            </view>
        </block>
        <view class="empty" wx:else>暂无战绩</view>
    </view>
</view>