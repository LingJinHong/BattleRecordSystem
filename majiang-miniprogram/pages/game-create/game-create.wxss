.label {
  margin: 20rpx 0 12rpx;
  font-size: 26rpx;
  color: #666;
}

.picker {
  display: flex;
  align-items: center;
}

.user-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.user-item {
  padding: 14rpx 18rpx;
  border: 1rpx solid #ddd;
  border-radius: 10rpx;
  font-size: 24rpx;
}

.user-item.active {
  border-color: #1677ff;
  color: #1677ff;
  background: #eef5ff;
}

.submit {
  margin-top: 24rpx;
}
