<view class="container">
  <view class="card">
    <view class="title">创建对局</view>

    <view class="label">选择小队</view>
    <picker range="{{teamList}}" range-key="teamName" bindchange="onTeamChange">
      <view class="input picker">{{selectedTeamId || '请选择小队'}}</view>
    </picker>

    <view class="label">选择玩家（多选）</view>
    <view class="user-list">
      <view
        class="user-item {{selectedUserIds.includes(item.friendUserId || item.userId) ? 'active' : ''}}"
        wx:for="{{userList}}"
        wx:key="friendUserId"
        data-id="{{item.friendUserId || item.userId}}"
        bindtap="toggleUser"
      >
        {{item.friendUserName || item.userName || ('用户' + (item.friendUserId || item.userId))}}
      </view>
    </view>

    <view class="btn-primary submit" bindtap="onSubmit">提交创建</view>
  </view>
</view>
