<view class="container">
  <view class="card">
    <view class="title">对局结算 #{{gameId}}</view>
    <view class="sub-title">请输入每位玩家输赢金额（支持正负数）</view>

    <view class="player-row" wx:for="{{players}}" wx:key="userId">
      <view class="name">{{item.name}}</view>
      <input
        class="input amount-input"
        type="digit"
        value="{{item.amount}}"
        placeholder="如：100 或 -50"
        data-idx="{{index}}"
        bindinput="onAmountInput"
      />
    </view>

    <view class="label">场地费（可选）</view>
    <input class="input" type="digit" value="{{venueFee}}" bindinput="onVenueFeeInput" />

    <view class="total {{totalAmount === 0 ? 'ok' : 'error'}}">当前总和：{{totalAmount}}</view>
    <view class="btn-primary {{totalAmount === 0 ? '' : 'disabled'}}" bindtap="onSubmit">提交结算</view>
  </view>
</view>
