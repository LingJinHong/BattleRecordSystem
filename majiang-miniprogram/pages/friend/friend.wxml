<view class="container">
  <view class="card">
    <view class="title">添加好友</view>
    <input class="input mt16" placeholder="输入好友用户ID" value="{{friendUserIdInput}}" bindinput="onInput" />
    <view class="btn-primary mt16" bindtap="onAddFriend">添加</view>
  </view>

  <view class="card">
    <view class="title">好友列表</view>
    <view class="friend-item" wx:for="{{friendList}}" wx:key="friendUserId">
      <view>{{item.friendUserName || ('用户' + item.friendUserId)}}</view>
      <view class="sub-title">ID: {{item.friendUserId}}</view>
    </view>
    <view class="empty" wx:if="{{!friendList.length}}">暂无好友</view>
  </view>
</view>
