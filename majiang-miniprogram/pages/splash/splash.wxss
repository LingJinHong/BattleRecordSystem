.login {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 120rpx 40rpx;
}

.title {
    font-size: 44rpx;
    font-weight: bold;
    margin-bottom: 16rpx;
    text-align: center;
}

.desc {
    font-size: 28rpx;
    color: #999;
    margin-top: 20rpx;
    text-align: center;
}

/* 头像按钮：清除所有默认样式，强制生效（微信原生写法） */
.avatar-btn {
    width: 160rpx;
    height: 160rpx;
    border-radius: 50%;
    padding: 0 !important;
    margin-bottom: 60rpx;
}

/* 头像图片：铺满按钮，圆角生效 */
.avatar-btn image {
    width: 160rpx;
    height: 160rpx;
    border-radius: 50%;
}

input {
    border-bottom: 1rpx solid #eee;
    padding: 20rpx;
    text-align: center;
    font-size: 30rpx;
    margin-bottom: 80rpx;
}

.submit-btn {
    background: #41e3da;
    color: #fff;
    border-radius: 50rpx;
    padding: 20rpx;
}