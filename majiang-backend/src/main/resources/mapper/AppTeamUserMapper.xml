<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.majiang.backend.mapper.AppTeamUserMapper">
    <resultMap id="BaseResultMap" type="com.majiang.backend.entity.AppTeamUser">
        <id property="id" column="id" />
        <result property="teamId" column="team_id" />
        <result property="userId" column="user_id" />
        <result property="createTime" column="create_time" />
    </resultMap>

    <insert id="insert" parameterType="com.majiang.backend.entity.AppTeamUser">
        INSERT INTO app_team_user (team_id, user_id, create_time)
        VALUES (#{teamId}, #{userId}, NOW())
    </insert>

    <delete id="deleteById" parameterType="long">
        DELETE FROM app_team_user WHERE id = #{id}
    </delete>

    <delete id="deleteByTeamIdAndUserId">
        DELETE FROM app_team_user WHERE team_id = #{teamId} AND user_id = #{userId}
    </delete>

    <update id="update" parameterType="com.majiang.backend.entity.AppTeamUser">
        UPDATE app_team_user
        SET team_id = #{teamId}, user_id = #{userId}
        WHERE id = #{id}
    </update>

    <select id="selectById" resultMap="BaseResultMap" parameterType="long">
        SELECT * FROM app_team_user WHERE id = #{id}
    </select>

    <select id="selectByTeamId" resultMap="BaseResultMap" parameterType="long">
        SELECT * FROM app_team_user WHERE team_id = #{teamId}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap" parameterType="long">
        SELECT * FROM app_team_user WHERE user_id = #{userId}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM app_team_user
    </select>
</mapper>
